{
	"kind": "singleType",
	"collectionName": "blogs",
	"info": {
		"singularName": "blog",
		"pluralName": "blogs",
		"displayName": "Blog"
	},
	"options": {
		"draftAndPublish": true
	},
	"pluginOptions": {},
	"attributes": {
		"title": {
			"type": "string",
			"required": true
		},
		"subTitle": {
			"type": "string"
		},
		"slug": {
			"type": "uid",
			"targetField": "title",
			"required": true
		},
		"content": {
			"type": "dynamiczone",
			"components": [
				"sections.paragraph",
				"sections.call-to-action",
				"sections.media"
			],
			"required": true
		},
		"metaData": {
			"type": "component",
			"component": "shared.seo",
			"repeatable": false,
			"required": true
		}
	}
}
