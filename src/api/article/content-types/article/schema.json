{
	"kind": "collectionType",
	"collectionName": "articles",
	"info": {
		"singularName": "article",
		"pluralName": "articles",
		"displayName": "Article"
	},
	"options": {
		"draftAndPublish": true
	},
	"pluginOptions": {},
	"attributes": {
		"title": {
			"type": "string",
			"minLength": 1,
			"maxLength": 255,
			"required": true
		},
		"summary": {
			"type": "blocks",
			"required": true
		},
		"slug": {
			"type": "uid",
			"targetField": "title",
			"required": true
		},
		"publicationDate": {
			"type": "date",
			"required": true
		},
		"preview": {
			"type": "media",
			"multiple": false,
			"required": true,
			"allowedTypes": ["images", "files"]
		},
		"tags": {
			"type": "relation",
			"relation": "oneToMany",
			"target": "api::tag.tag"
		},
		"authors": {
			"type": "relation",
			"relation": "manyToMany",
			"target": "api::author.author",
			"mappedBy": "articles"
		},
		"content": {
			"type": "dynamiczone",
			"components": [
				"sections.reference-list",
				"sections.picture",
				"sections.paragraph",
				"sections.internal-video",
				"sections.gallery",
				"sections.embedded-video",
				"sections.call-to-action"
			],
			"required": true
		},
		"metaData": {
			"type": "component",
			"component": "shared.seo",
			"repeatable": false,
			"required": true
		}
	}
}
