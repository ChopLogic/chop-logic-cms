{
	"$schema": "https://biomejs.dev/schemas/2.4.7/schema.json",
	"files": {
		"includes": [
			"**",
			"!**/dist",
			"!**/.tmp",
			"!**/.strapi",
			"!**/coverage",
			"!**/node_modules",
			"!**/types/generated"
		]
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		},
		"domains": {
			"project": "recommended",
			"test": "recommended"
		}
	},
	"formatter": {
		"enabled": true
	}
}
