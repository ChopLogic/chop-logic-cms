{
	"kind": "collectionType",
	"collectionName": "chapters",
	"info": {
		"singularName": "chapter",
		"pluralName": "chapters",
		"displayName": "Chapter"
	},
	"options": {
		"draftAndPublish": true
	},
	"pluginOptions": {},
	"attributes": {
		"title": {
			"type": "string",
			"required": true
		},
		"slug": {
			"type": "uid",
			"targetField": "title",
			"required": true
		},
		"level": {
			"type": "enumeration",
			"required": true,
			"enum": ["chapter", "section", "subsection", "frontmatter", "backmatter"]
		},
		"order": {
			"type": "integer",
			"required": true
		},
		"book": {
			"type": "relation",
			"relation": "manyToOne",
			"target": "api::book.book",
			"inversedBy": "chapters"
		},
		"content": {
			"type": "dynamiczone",
			"components": [
				"sections.picture",
				"sections.paragraph",
				"sections.internal-video",
				"sections.gallery",
				"sections.embedded-video",
				"sections.call-to-action"
			],
			"required": true
		},
		"references": {
			"type": "component",
			"component": "sections.reference-list",
			"repeatable": false
		},
		"metaData": {
			"type": "component",
			"component": "shared.seo",
			"repeatable": false
		}
	}
}
