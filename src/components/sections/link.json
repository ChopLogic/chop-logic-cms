{
	"collectionName": "components_sections_links",
	"info": {
		"displayName": "Link",
		"icon": "link"
	},
	"options": {},
	"attributes": {
		"text": {
			"type": "string",
			"required": true
		},
		"url": {
			"type": "string",
			"required": true
		},
		"platform": {
			"type": "enumeration",
			"enum": [
				"LinkedIn",
				"Facebook",
				"Telegram",
				"YouTube",
				"WhatsApp",
				"Instagram",
				"TikTok",
				"Reddit",
				"Pinterest",
				"X/Twitter",
				"Medium",
				"Discord",
				"GitHub"
			]
		},
		"icon": {
			"type": "media",
			"multiple": false,
			"allowedTypes": ["images", "files"]
		},
		"target": {
			"type": "enumeration",
			"default": "_blank",
			"enum": ["_blank", "_self", "_parent", "_top"]
		},
		"referrerpolicy": {
			"type": "enumeration",
			"default": "strict-origin-when-cross-origin",
			"enum": [
				"no-referrer",
				"no-referrer-when-downgrade",
				"origin",
				"origin-when-cross-origin",
				"same-origin",
				"strict-origin",
				"strict-origin-when-cross-origin",
				"unsafe-url"
			]
		}
	},
	"config": {}
}
