{
	"kind": "collectionType",
	"collectionName": "articles",
	"info": {
		"singularName": "article",
		"pluralName": "articles",
		"displayName": "Article"
	},
	"options": {
		"draftAndPublish": true
	},
	"pluginOptions": {},
	"attributes": {
		"title": {
			"type": "string",
			"minLength": 1,
			"maxLength": 255,
			"required": true
		},
		"published": {
			"type": "datetime",
			"required": true
		},
		"summary": {
			"type": "blocks",
			"required": true
		},
		"preview": {
			"type": "media",
			"multiple": false,
			"required": true,
			"allowedTypes": ["images", "files"]
		}
	}
}
