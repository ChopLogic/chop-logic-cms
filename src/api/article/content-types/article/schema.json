{
	"kind": "collectionType",
	"collectionName": "articles",
	"info": {
		"singularName": "article",
		"pluralName": "articles",
		"displayName": "Article"
	},
	"options": {
		"draftAndPublish": true
	},
	"pluginOptions": {},
	"attributes": {
		"title": {
			"type": "string",
			"minLength": 1,
			"maxLength": 255,
			"required": true
		},
		"slug": {
			"type": "uid",
			"targetField": "title",
			"required": true
		},
		"tags": {
			"type": "relation",
			"relation": "oneToMany",
			"target": "api::tag.tag"
		},
		"preview": {
			"type": "media",
			"multiple": false,
			"required": true,
			"allowedTypes": ["images", "files"]
		},
		"summary": {
			"type": "blocks",
			"required": true
		},
		"body": {
			"type": "blocks",
			"required": true
		},
		"publicationDate": {
			"type": "date",
			"required": true
		},
		"metaData": {
			"type": "component",
			"component": "shared.seo",
			"repeatable": false
		}
	}
}
