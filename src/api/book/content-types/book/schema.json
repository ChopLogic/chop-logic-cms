{
	"kind": "collectionType",
	"collectionName": "books",
	"info": {
		"singularName": "book",
		"pluralName": "books",
		"displayName": "Book"
	},
	"options": {
		"draftAndPublish": true
	},
	"pluginOptions": {},
	"attributes": {
		"title": {
			"type": "string",
			"required": true
		},
		"slug": {
			"type": "uid",
			"targetField": "title",
			"required": true
		},
		"authors": {
			"type": "relation",
			"relation": "manyToMany",
			"target": "api::author.author",
			"inversedBy": "books"
		},
		"annotation": {
			"type": "text",
			"required": true
		},
		"ISBN": {
			"type": "string"
		},
		"copyright": {
			"type": "blocks",
			"required": true
		},
		"chapters": {
			"type": "relation",
			"relation": "oneToMany",
			"target": "api::chapter.chapter",
			"mappedBy": "book"
		},
		"metaData": {
			"type": "component",
			"component": "shared.seo",
			"repeatable": false
		}
	}
}
